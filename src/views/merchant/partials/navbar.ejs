<%
const userInitial = (merchant?.name || 'T').trim().charAt(0).toUpperCase();
const navTitleKey = typeof pageTitleKey !== 'undefined' ? pageTitleKey : 'nav.home';
%>
<header class="pos-navbar">
    <button type="button" class="pos-toggle" id="sidebarToggle" aria-label="menu">
        <i class="fas fa-bars"></i>
    </button>

    <h1 class="pos-page-title d-none d-md-block" data-i18n="<%= navTitleKey %>"></h1>

    <div class="pos-navbar-actions ms-auto">
        <%- include('./lang-switcher', { navbar: true }) %>

        <div class="pos-user-profile">
            <div class="pos-user-avatar mpr-user-avatar"><%= userInitial %></div>
            <div class="pos-user-info d-none d-sm-block">
                <strong><%= merchant?.name || '—' %></strong>
                <small><%= company?.name || '—' %></small>
            </div>
        </div>

        <button type="button" class="btn btn-pos-outline btn-sm d-md-none" id="logoutBtnMobile">
            <i class="fas fa-sign-out-alt"></i>
        </button>
    </div>
</header>

<script>
document.getElementById('logoutBtnMobile')?.addEventListener('click', () => {
    document.getElementById('logoutBtn')?.click();
});
</script>
