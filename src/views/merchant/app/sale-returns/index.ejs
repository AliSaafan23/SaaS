<div class="pos-card mb-3">
    <div class="pos-card-body">
        <div class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label" data-i18n="common.branch">الفرع</label>
                <select class="form-select" id="filterBranch">
                    <option value="" data-i18n="common.all">الكل</option>
                    <% branches.forEach((b) => { %>
                    <option value="<%= b.id %>"><%= b.name %></option>
                    <% }) %>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label" data-i18n="saleReturns.from">من</label>
                <input type="date" class="form-control" id="filterFrom">
            </div>
            <div class="col-md-3">
                <label class="form-label" data-i18n="saleReturns.to">إلى</label>
                <input type="date" class="form-control" id="filterTo">
            </div>
            <div class="col-md-3">
                <button class="btn btn-pos-primary w-100" id="filterBtn">
                    <i class="fas fa-search"></i> <span data-i18n="common.refresh">تحديث</span>
                </button>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-4">
        <div class="mpr-stat-card">
            <small data-i18n="saleReturns.count">عدد المرتجعات</small>
            <strong id="statReturnCount">—</strong>
        </div>
    </div>
    <div class="col-md-4">
        <div class="mpr-stat-card">
            <small data-i18n="saleReturns.total">إجمالي المرتجعات</small>
            <strong id="statReturnTotal">—</strong>
        </div>
    </div>
</div>

<div class="pos-card">
    <div class="pos-card-header">
        <h4 class="mb-0"><i class="fas fa-undo text-pos-primary"></i> <span data-i18n="saleReturns.title">مرتجعات البيع</span></h4>
    </div>
    <div class="table-responsive">
        <table class="table pos-table" id="returnsTable">
            <thead>
                <tr>
                    <th data-i18n="saleReturns.returnNo">رقم المرتجع</th>
                    <th data-i18n="saleReturns.invoiceNo">فاتورة البيع</th>
                    <th data-i18n="common.branch">الفرع</th>
                    <th data-i18n="common.name">العميل</th>
                    <th data-i18n="saleReturns.total">الإجمالي</th>
                    <th data-i18n="saleReturns.date">التاريخ</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>
<script src="/merchant/js/sale-returns.js"></script>
