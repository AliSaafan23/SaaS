<div class="pos-card">
    <div class="pos-card-header d-flex flex-wrap justify-content-between align-items-center gap-2">
        <h4 class="mb-0"><i class="fas fa-cash-register text-pos-primary"></i> <span data-i18n="cashiers.title">الكاشيرز</span></h4>
        <button class="btn btn-pos-primary btn-sm" id="addCashierBtn">
            <i class="fas fa-plus"></i> <span data-i18n="cashiers.new">كاشير جديد</span>
        </button>
    </div>
    <div class="table-responsive">
        <table class="table pos-table" id="cashiersTable">
            <thead>
                <tr>
                    <th data-i18n="common.name">الاسم</th>
                    <th data-i18n="common.email">البريد</th>
                    <th data-i18n="common.branch">الفرع</th>
                    <th data-i18n="common.status">الحالة</th>
                    <th></th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="cashierModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="cashierModalTitle" data-i18n="cashiers.new">كاشير جديد</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="cashierForm">
                <div class="modal-body">
                    <div id="cashierAlert" class="alert d-none"></div>
                    <input type="hidden" name="id" id="cashierId">
                    <div class="mb-3">
                        <label class="form-label" data-i18n="common.branch">الفرع</label>
                        <select name="branchId" id="cashierBranchId" class="form-select" required></select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" data-i18n="common.name">الاسم</label>
                        <input type="text" name="name" class="form-control" required>
                    </div>
                    <div class="mb-3" id="emailFieldWrap">
                        <label class="form-label" data-i18n="common.email">البريد</label>
                        <input type="email" name="email" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" data-i18n="common.phone">الهاتف</label>
                        <input type="tel" name="phone" class="form-control">
                    </div>
                    <div class="mb-3" id="passwordFieldWrap">
                        <label class="form-label" data-i18n="common.password">كلمة المرور</label>
                        <div class="pos-password-wrap">
                            <input type="password" name="password" id="cashierPassword" class="form-control mpr-password-input" minlength="8" autocomplete="new-password">
                            <button type="button" class="pos-auth-eye" id="toggleCashierPassword" data-i18n-title="common.showPassword" aria-label="إظهار كلمة المرور">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" data-i18n="common.cancel">إلغاء</button>
                    <button type="submit" class="btn btn-pos-primary" data-i18n="common.save">حفظ</button>
                </div>
            </form>
        </div>
    </div>
</div>
<script src="/merchant/js/cashiers.js"></script>
