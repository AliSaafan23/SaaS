<div class="pos-login-shell">
    <div class="pos-auth-wrap mpr-auth-center-wrap">
        <%- include('../partials/lang-switcher') %>
        <div class="pos-auth-card mpr-auth-center mx-auto">
            <div class="pos-auth-card-inner">
                <div class="pos-auth-header">
                    <h2 data-i18n="auth.reset.title">إعادة تعيين كلمة المرور</h2>
                    <p data-i18n="auth.reset.subtitle">أدخل الكود وكلمة المرور الجديدة</p>
                </div>
                <div id="resetAlert" class="alert d-none pos-alert"></div>
                <form id="resetForm" class="pos-auth-form">
                    <div class="mb-3">
                        <label class="form-label pos-auth-label" data-i18n="auth.reset.email">البريد الإلكتروني</label>
                        <input type="email" name="email" class="form-control pos-auth-input" value="<%= email %>" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label pos-auth-label" data-i18n="auth.reset.code">كود التحقق</label>
                        <input type="text" name="code" class="form-control pos-auth-input" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label pos-auth-label" data-i18n="auth.reset.password">كلمة المرور الجديدة</label>
                        <input type="password" name="password" class="form-control pos-auth-input" required minlength="8">
                    </div>
                    <div class="mb-3">
                        <label class="form-label pos-auth-label" data-i18n="auth.reset.confirmPassword">تأكيد كلمة المرور</label>
                        <input type="password" name="confirmPassword" class="form-control pos-auth-input" required minlength="8">
                    </div>
                    <button type="submit" class="btn btn-pos-login w-100" data-i18n="auth.reset.submit">حفظ كلمة المرور</button>
                </form>
            </div>
        </div>
    </div>
</div>
