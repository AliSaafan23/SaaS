<div class="pos-login-shell">
    <div class="pos-auth-wrap mpr-auth-center-wrap">
        <%- include('../partials/lang-switcher') %>
        <div class="pos-auth-card mpr-auth-center mx-auto" data-resent="<%= resent ? '1' : '0' %>">
            <div class="pos-auth-card-inner">
                <div class="pos-auth-header text-center">
                    <div class="mpr-auth-icon">
                        <i class="fas fa-envelope-open-text"></i>
                    </div>
                    <h2 data-i18n="auth.verify.title">تفعيل البريد الإلكتروني</h2>
                    <p data-i18n="auth.verify.subtitle">أدخل الكود المرسل إلى بريدك</p>
                </div>
                <div id="verifyResentAlert" class="alert alert-success pos-alert d-none"></div>
                <div id="verifyAlert" class="alert d-none pos-alert"></div>
                <form id="verifyForm" class="pos-auth-form">
                    <div class="mb-3">
                        <label class="form-label pos-auth-label" data-i18n="auth.verify.email">البريد الإلكتروني</label>
                        <input type="email" name="email" class="form-control pos-auth-input" value="<%= email %>" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label pos-auth-label" data-i18n="auth.verify.code">كود التفعيل</label>
                        <input type="text" name="code" class="form-control pos-auth-input text-center" maxlength="6" required placeholder="123456">
                    </div>
                    <button type="submit" class="btn btn-pos-login w-100" id="verifyBtn" data-i18n="auth.verify.submit">تفعيل الحساب</button>
                </form>
                <div class="text-center mt-3">
                    <button type="button" class="btn btn-link btn-sm" id="resendBtn" data-i18n="auth.verify.resend">إعادة إرسال الكود</button>
                </div>
                <p class="text-center mt-3 mb-0"><a href="/merchant/login" data-i18n="auth.verify.backLogin">العودة لتسجيل الدخول</a></p>
            </div>
        </div>
    </div>
</div>
