<div class="pos-login-shell">
    <div class="pos-auth-wrap mpr-auth-center-wrap">
        <%- include('../partials/lang-switcher') %>
        <div class="pos-auth-card mpr-auth-center mx-auto">
            <div class="pos-auth-card-inner">
                <div class="pos-auth-header">
                    <h2 data-i18n="auth.forgot.title">نسيت كلمة المرور</h2>
                    <p data-i18n="auth.forgot.subtitle">سنرسل كود إعادة التعيين إلى بريدك</p>
                </div>
                <div id="forgotAlert" class="alert d-none pos-alert"></div>
                <form id="forgotForm" class="pos-auth-form">
                    <div class="mb-3">
                        <label class="form-label pos-auth-label" data-i18n="auth.forgot.email">البريد الإلكتروني</label>
                        <input type="email" name="email" class="form-control pos-auth-input" required>
                    </div>
                    <button type="submit" class="btn btn-pos-login w-100" data-i18n="auth.forgot.submit">إرسال الكود</button>
                </form>
                <p class="text-center mt-3 mb-0"><a href="/merchant/login" data-i18n="auth.forgot.backLogin">العودة لتسجيل الدخول</a></p>
            </div>
        </div>
    </div>
</div>
