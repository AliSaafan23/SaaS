<%
const initials = (user?.name || 'U').trim().split(/\s+/).slice(0, 2).map((p) => p[0]?.toUpperCase()).join('');
%>
<header class="saas-topbar">
    <div class="saas-topbar__start">
        <button type="button" class="pos-toggle" id="sidebarToggle" aria-label="Menu">
            <i class="fas fa-bars"></i>
        </button>
        <div>
            <h1 class="saas-topbar__title" data-i18n="<%= pageTitleKey %>">Dashboard</h1>
            <div class="saas-topbar__crumb"><%= user?.tenant?.name || '' %></div>
        </div>
    </div>
    <div class="d-flex align-items-center gap-3">
        <%- include('lang-switcher', { navbar: true }) %>
        <div class="saas-user-chip">
            <div class="saas-user-chip__avatar"><%= initials %></div>
            <div class="saas-user-chip__meta">
                <strong><%= user?.name || '' %></strong>
                <small><%= user?.email || '' %></small>
            </div>
        </div>
    </div>
</header>
