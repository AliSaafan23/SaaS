<div class="row g-4">
    <div class="col-lg-5">
        <div class="pos-card">
            <div class="pos-card-header">
                <h4><i class="fas fa-globe text-pos-primary"></i> <span id="countryFormTitle" data-i18n="countries.formAddTitle">إضافة دولة</span></h4>
            </div>
            <div id="countryFormAlert" class="alert d-none pos-alert"></div>
            <form id="countryForm">
                <input type="hidden" name="id" id="countryId">
                <div class="mb-3">
                    <label class="form-label" data-i18n="countries.nameAr">الاسم (عربي)</label>
                    <input type="text" name="nameAr" class="form-control pos-input" required>
                </div>
                <div class="mb-3">
                    <label class="form-label" data-i18n="countries.nameEn">الاسم (إنجليزي)</label>
                    <input type="text" name="nameEn" class="form-control pos-input" required>
                </div>
                <div class="row g-2">
                    <div class="col-6 mb-3">
                        <label class="form-label" data-i18n="countries.code">كود الدولة</label>
                        <input type="text" name="code" class="form-control pos-input" maxlength="5" required placeholder="EG">
                    </div>
                    <div class="col-6 mb-3">
                        <label class="form-label" data-i18n="countries.phoneCode">كود الهاتف</label>
                        <input type="text" name="phoneCode" class="form-control pos-input" placeholder="+20">
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label" data-i18n="countries.sortOrder">ترتيب العرض</label>
                    <input type="number" name="sortOrder" class="form-control pos-input" min="0" value="0">
                </div>
                <div class="mb-3 form-check">
                    <input type="checkbox" name="isActive" class="form-check-input" id="countryIsActive" checked>
                    <label class="form-check-label" for="countryIsActive" data-i18n="countries.isActive">نشطة (تظهر في التسجيل)</label>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-pos-primary flex-fill" data-i18n="countries.save">حفظ</button>
                    <button type="button" class="btn btn-pos-outline d-none" id="cancelCountryEdit" data-i18n="common.cancel">إلغاء</button>
                </div>
            </form>
        </div>
    </div>
    <div class="col-lg-7">
        <div class="pos-card">
            <div class="pos-card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                <h4><i class="fas fa-list text-pos-primary"></i> <span data-i18n="countries.listTitle">قائمة الدول</span></h4>
                <button class="btn btn-pos-outline btn-sm" id="refreshCountries"><i class="fas fa-sync"></i></button>
            </div>
            <div class="table-responsive">
                <table class="table pos-table" id="countriesTable">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th data-i18n="countries.colName">الدولة</th>
                            <th data-i18n="countries.code">الكود</th>
                            <th data-i18n="countries.phoneCode">الهاتف</th>
                            <th data-i18n="countries.colStatus">الحالة</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>
<script src="/admin/js/countries.js"></script>
