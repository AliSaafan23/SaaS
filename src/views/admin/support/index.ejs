                    <th data-i18n="support.colSubject">الموضوع</th>
                    <th data-i18n="support.colStatus">الحالة</th>
                    <th data-i18n="support.colDate">التاريخ</th>
                    <th></th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<script src="/admin/js/support.js"></script>
