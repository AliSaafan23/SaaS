<div class="pos-card">
    <div class="pos-card-header">
        <h4><i class="fas fa-sliders-h text-pos-primary"></i> <span data-i18n="settings.title">إعدادات النظام</span></h4>
    </div>
    <div id="settingsAlert" class="alert d-none pos-alert"></div>

    <ul class="nav nav-tabs pos-settings-tabs mb-4" id="settingsTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#settingsGeneral" type="button" data-i18n="settings.tabGeneral">عام</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#settingsSecurity" type="button" data-i18n="settings.tabSecurity">الأمان</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#settingsEmail" type="button" data-i18n="settings.tabEmail">البريد / SMTP</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#settingsSms" type="button" data-i18n="settings.tabSms">SMS</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#settingsSubscription" type="button" data-i18n="settings.tabSubscription">الاشتراك والحماية</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#settingsPaymentMethods" type="button" data-i18n="settings.tabPaymentMethods">طرق الدفع</button>
        </li>
    </ul>

    <div class="tab-content">
        <div class="tab-pane fade show active" id="settingsGeneral" role="tabpanel">
            <form class="settings-form" data-key="general">
                <div class="mb-3">
                    <label class="form-label" data-i18n="settings.platformName">اسم المنصة</label>
                    <input type="text" name="platformName" class="form-control pos-input">
                </div>
                <div class="mb-3">
                    <label class="form-label" data-i18n="settings.defaultLang">اللغة الافتراضية</label>
                    <select name="defaultLang" class="form-select pos-input">
                        <option value="ar" data-i18n="common.langAr">العربية</option>
                        <option value="en" data-i18n="common.langEn">English</option>
                    </select>
                </div>
                <button type="submit" class="btn btn-pos-primary" data-i18n="settings.saveGeneral">حفظ الإعدادات العامة</button>
            </form>
        </div>
        <div class="tab-pane fade" id="settingsSecurity" role="tabpanel">
            <form class="settings-form" data-key="security">
                <div class="mb-3">
                    <label class="form-label" data-i18n="settings.sessionTimeout">مدة الجلسة (دقيقة)</label>
                    <input type="number" name="sessionTimeout" class="form-control pos-input" min="5">
                </div>
                <div class="mb-3 form-check">
                    <input type="checkbox" name="force2fa" class="form-check-input" id="force2fa">
                    <label class="form-check-label" for="force2fa" data-i18n="settings.force2fa">إلزام المصادقة الثنائية</label>
                </div>
                <button type="submit" class="btn btn-pos-primary" data-i18n="settings.saveSecurity">حفظ إعدادات الأمان</button>
            </form>
        </div>
        <div class="tab-pane fade" id="settingsEmail" role="tabpanel">
            <form class="settings-form" data-key="email">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label" data-i18n="settings.smtpHost">SMTP Host</label>
                        <input type="text" name="smtpHost" class="form-control pos-input">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" data-i18n="settings.smtpPort">SMTP Port</label>
                        <input type="number" name="smtpPort" class="form-control pos-input">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" data-i18n="settings.smtpUser">المستخدم</label>
                        <input type="text" name="smtpUser" class="form-control pos-input">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" data-i18n="settings.smtpPass">كلمة المرور</label>
                        <input type="password" name="smtpPass" class="form-control pos-input">
                    </div>
                </div>
                <button type="submit" class="btn btn-pos-primary mt-3" data-i18n="settings.saveEmail">حفظ إعدادات البريد</button>
            </form>
        </div>
        <div class="tab-pane fade" id="settingsSms" role="tabpanel">
            <form class="settings-form" data-key="sms">
                <div class="mb-3">
                    <label class="form-label" data-i18n="settings.provider">مزود الخدمة</label>
                    <input type="text" name="provider" class="form-control pos-input">
                </div>
                <div class="mb-3">
                    <label class="form-label" data-i18n="settings.apiKey">API Key</label>
                    <input type="text" name="apiKey" class="form-control pos-input">
                </div>
                <div class="mb-3">
                    <label class="form-label" data-i18n="settings.senderId">Sender ID</label>
                    <input type="text" name="senderId" class="form-control pos-input">
                </div>
                <button type="submit" class="btn btn-pos-primary" data-i18n="settings.saveSms">حفظ إعدادات SMS</button>
            </form>
        </div>
        <div class="tab-pane fade" id="settingsSubscription" role="tabpanel">
            <form class="settings-form" data-key="subscription">
                <p class="text-muted small" data-i18n="settings.subscriptionHint">الميزات المحددة هنا تعمل بدون اشتراك نشط. باقي الراوتات المحمية بـ requireSubscription تحتاج تفعيل من لوحة المشتركون.</p>
                <div id="freeFeaturesCheckboxes" class="row g-2 mb-3"></div>
                <div class="mb-3">
                    <label class="form-label" data-i18n="settings.lockedMessage">رسالة القفل (عربي)</label>
                    <input type="text" name="lockedMessageAr" class="form-control pos-input" data-i18n-placeholder="settings.lockedPlaceholder" placeholder="فعّل اشتراكك للوصول لهذه الميزة">
                </div>
                <button type="submit" class="btn btn-pos-primary" data-i18n="settings.saveSubscription">حفظ إعدادات الاشتراك</button>
            </form>
        </div>
        <div class="tab-pane fade" id="settingsPaymentMethods" role="tabpanel">
            <div class="row g-4">
                <div class="col-lg-5">
                    <div class="pos-card border-0 shadow-none p-0">
                        <h5 class="mb-3" id="pmFormTitle" data-i18n="paymentMethods.formAddTitle">إضافة طريقة دفع</h5>
                        <div id="pmFormAlert" class="alert d-none pos-alert"></div>
                        <form id="paymentMethodForm">
                            <input type="hidden" name="id" id="pmId">
                            <div class="mb-3">
                                <label class="form-label" data-i18n="paymentMethods.nameAr">الاسم (عربي)</label>
                                <input type="text" name="nameAr" class="form-control pos-input" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label" data-i18n="paymentMethods.nameEn">الاسم (إنجليزي)</label>
                                <input type="text" name="nameEn" class="form-control pos-input" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label" data-i18n="paymentMethods.code">الكود</label>
                                <input type="text" name="code" class="form-control pos-input" maxlength="30" required placeholder="cash">
                                <div class="form-text" data-i18n="paymentMethods.codeHint">حروف إنجليزية صغيرة — cash, card, credit, cheque</div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label" data-i18n="paymentMethods.sortOrder">ترتيب العرض</label>
                                <input type="number" name="sortOrder" class="form-control pos-input" min="0" value="0">
                            </div>
                            <div class="mb-3 form-check">
                                <input type="checkbox" name="affectsCashbox" class="form-check-input" id="pmAffectsCashbox" checked>
                                <label class="form-check-label" for="pmAffectsCashbox" data-i18n="paymentMethods.affectsCashbox">يؤثر على الصندوق</label>
                            </div>
                            <div class="mb-3 form-check">
                                <input type="checkbox" name="requiresCustomer" class="form-check-input" id="pmRequiresCustomer">
                                <label class="form-check-label" for="pmRequiresCustomer" data-i18n="paymentMethods.requiresCustomer">يتطلب عميلاً</label>
                            </div>
                            <div class="mb-3 form-check">
                                <input type="checkbox" name="isActive" class="form-check-input" id="pmIsActive" checked>
                                <label class="form-check-label" for="pmIsActive" data-i18n="paymentMethods.isActive">نشطة (تظهر في الكاشير)</label>
                            </div>
                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-pos-primary flex-fill" data-i18n="paymentMethods.save">حفظ</button>
                                <button type="button" class="btn btn-pos-outline d-none" id="cancelPmEdit" data-i18n="common.cancel">إلغاء</button>
                            </div>
                        </form>
                    </div>
                </div>
                <div class="col-lg-7">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="mb-0" data-i18n="paymentMethods.listTitle">قائمة طرق الدفع</h5>
                        <button class="btn btn-pos-outline btn-sm" id="refreshPaymentMethods"><i class="fas fa-sync"></i></button>
                    </div>
                    <div class="table-responsive">
                        <table class="table pos-table" id="paymentMethodsTable">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th data-i18n="paymentMethods.colName">الاسم</th>
                                    <th data-i18n="paymentMethods.code">الكود</th>
                                    <th data-i18n="paymentMethods.colCashbox">الصندوق</th>
                                    <th data-i18n="paymentMethods.colStatus">الحالة</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="/admin/js/settings.js"></script>
<script src="/admin/js/payment-methods.js"></script>
