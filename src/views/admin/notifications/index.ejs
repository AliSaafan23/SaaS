<div class="row g-4">
    <div class="col-lg-4">
        <div class="pos-card">
            <div class="pos-card-header">
                <h4><i class="fas fa-paper-plane text-pos-primary"></i> <span data-i18n="notifications.sendTitle">إرسال إشعار</span></h4>
            </div>
            <div id="notifFormAlert" class="alert d-none pos-alert"></div>
            <form id="notifForm">
                <div class="mb-3">
                    <label class="form-label" data-i18n="notifications.title">العنوان</label>
                    <input type="text" name="title" class="form-control pos-input" required>
                </div>
                <div class="mb-3">
                    <label class="form-label" data-i18n="notifications.message">الرسالة</label>
                    <textarea name="message" class="form-control pos-input" rows="4" required></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label" data-i18n="notifications.type">النوع</label>
                    <select name="type" class="form-select pos-input">
                        <option value="system" data-i18n="notifications.typeSystem">نظام</option>
                        <option value="alert" data-i18n="notifications.typeAlert">تنبيه</option>
                        <option value="info" data-i18n="notifications.typeInfo">معلومات</option>
                    </select>
                </div>
                <button type="submit" class="btn btn-pos-primary w-100" data-i18n="notifications.submit">إرسال</button>
            </form>
        </div>
    </div>
    <div class="col-lg-8">
        <div class="pos-card">
            <div class="pos-card-header d-flex justify-content-between align-items-center">
                <h4><i class="fas fa-bell text-pos-primary"></i> <span data-i18n="notifications.listTitle">الإشعارات الأخيرة</span></h4>
                <button class="btn btn-pos-outline btn-sm" id="refreshNotifications"><i class="fas fa-sync"></i></button>
            </div>
            <div class="table-responsive">
                <table class="table pos-table" id="notificationsTable">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th data-i18n="notifications.colTitle">العنوان</th>
                            <th data-i18n="notifications.colType">النوع</th>
                            <th data-i18n="notifications.colDate">التاريخ</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script src="/admin/js/notifications.js"></script>
