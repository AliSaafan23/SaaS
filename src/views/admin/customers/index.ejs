<div class="saas-page saas-animate-in">
    <%- include('../../partials/page-header', { titleKey: 'customers.title', descKey: 'customers.desc' }) %>
    <div id="customerAlert" class="alert d-none saas-alert"></div>

    <div class="saas-panel">
        <div class="saas-panel__head"><h3 data-i18n="customers.add">إضافة عميل</h3></div>
        <div class="saas-panel__body">
            <form id="customerForm">
                <input type="hidden" id="customerId">
                <div class="saas-form-card">
                    <div class="saas-form-grid">
                        <div class="saas-field saas-col-4">
                            <label data-i18n="customers.name">الاسم</label>
                            <input class="form-control" name="name" required>
                        </div>
                        <div class="saas-field saas-col-4">
                            <label data-i18n="customers.email">البريد</label>
                            <input class="form-control" name="email" type="email">
                        </div>
                        <div class="saas-field saas-col-4">
                            <label data-i18n="customers.avatar">صورة العميل</label>
                            <input class="form-control" name="avatar" type="file" accept="image/png,image/jpeg,image/webp">
                        </div>
                        <div class="saas-field saas-col-2">
                            <label>&nbsp;</label>
                            <button class="btn saas-btn-primary w-100" type="submit" data-i18n="common.save">حفظ</button>
                        </div>
                    </div>
                </div>
            </form>
            <div class="saas-table-wrap">
                <table class="saas-table" id="customersTable">
                    <thead><tr><th>#</th><th></th><th data-i18n="customers.name">الاسم</th><th data-i18n="customers.email">البريد</th><th data-i18n="common.actions">إجراءات</th></tr></thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>
<script src="/admin/js/customers.js"></script>
