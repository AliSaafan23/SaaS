<div class="saas-page">
    <%- include('../../partials/page-header', { titleKey: 'plans.title', descKey: 'plans.desc' }) %>

    <div id="planAlert" class="alert d-none saas-alert"></div>

    <div class="saas-panel">
        <div class="saas-panel__head">
            <h3 data-i18n="plans.add">إضافة خطة</h3>
        </div>
        <div class="saas-panel__body">
            <form id="planForm">
                <input type="hidden" name="id" id="planId">
                <div class="saas-form-card">
                    <div class="saas-form-card__title" data-i18n="plans.formTitle">بيانات الخطة</div>
                    <div class="saas-form-grid">
                        <div class="saas-field saas-col-3">
                            <label data-i18n="plans.name">الاسم</label>
                            <input class="form-control" name="name" placeholder="Bronze" required>
                        </div>
                        <div class="saas-field saas-col-2">
                            <label data-i18n="plans.price">السعر</label>
                            <input class="form-control" name="price" type="number" step="0.01" placeholder="100" required>
                        </div>
                        <div class="saas-field saas-col-2">
                            <label data-i18n="plans.cycle">الدورة</label>
                            <select class="form-select" name="billingCycle">
                                <option value="monthly" data-i18n="plans.monthly">شهري</option>
                                <option value="annual" data-i18n="plans.annual">سنوي</option>
                            </select>
                        </div>
                        <div class="saas-field saas-col-2">
                            <label>&nbsp;</label>
                            <button class="btn saas-btn-primary w-100" type="submit" data-i18n="common.save">حفظ</button>
                        </div>
                    </div>
                </div>
            </form>

            <div class="saas-table-wrap">
                <table class="saas-table" id="plansTable">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th data-i18n="plans.name">الاسم</th>
                            <th data-i18n="plans.price">السعر</th>
                            <th data-i18n="plans.cycle">الدورة</th>
                            <th data-i18n="common.actions">إجراءات</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>
<script src="/admin/js/plans.js"></script>
