<div class="saas-page saas-animate-in">
    <%- include('../../partials/page-header', { titleKey: 'reports.title', descKey: 'reports.desc' }) %>
    <div class="saas-howto"><span class="saas-howto__icon"><i class="fas fa-circle-info"></i></span><p data-i18n="reports.howto"></p></div>

    <div class="saas-report-grid">
        <div class="saas-panel saas-panel--accent saas-stagger-item">
            <div class="saas-panel__head">
                <div class="saas-panel__title-wrap">
                    <span class="saas-panel__icon pos-icon-green"><i class="fas fa-chart-bar"></i></span>
                    <h3 data-i18n="reports.incomeStatement">قائمة الدخل</h3>
                </div>
            </div>
            <div class="saas-panel__body">
                <form id="incomeForm" class="saas-form-grid mb-3">
                    <div class="saas-field saas-col-6">
                        <label data-i18n="reports.from">من</label>
                        <input class="form-control" name="from" type="date" required>
                    </div>
                    <div class="saas-field saas-col-6">
                        <label data-i18n="reports.to">إلى</label>
                        <input class="form-control" name="to" type="date" required>
                    </div>
                    <div class="saas-field saas-col-12">
                        <button class="btn saas-btn-primary saas-btn-with-icon" type="submit">
                            <i class="fas fa-play"></i><span data-i18n="reports.run">تشغيل</span>
                        </button>
                    </div>
                </form>
                <div id="incomeResult" class="saas-report-output">
                    <div class="saas-report-placeholder">
                        <i class="fas fa-chart-line"></i>
                        <p data-i18n="reports.incomeHint">اختر الفترة واضغط تشغيل لعرض إيرادات الاشتراكات</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="saas-panel saas-panel--accent saas-stagger-item">
            <div class="saas-panel__head">
                <div class="saas-panel__title-wrap">
                    <span class="saas-panel__icon pos-icon-blue"><i class="fas fa-balance-scale"></i></span>
                    <h3 data-i18n="reports.balanceSheet">الميزانية العمومية</h3>
                </div>
            </div>
            <div class="saas-panel__body">
                <form id="balanceForm" class="saas-form-grid mb-3">
                    <div class="saas-field saas-col-8">
                        <label data-i18n="reports.asOf">حتى تاريخ</label>
                        <input class="form-control" name="asOf" type="date" required>
                    </div>
                    <div class="saas-field saas-col-4">
                        <label>&nbsp;</label>
                        <button class="btn saas-btn-primary saas-btn-with-icon w-100" type="submit">
                            <i class="fas fa-play"></i><span data-i18n="reports.run">تشغيل</span>
                        </button>
                    </div>
                </form>
                <div id="balanceResult" class="saas-report-output">
                    <div class="saas-report-placeholder">
                        <i class="fas fa-landmark"></i>
                        <p data-i18n="reports.balanceHint">اختر التاريخ لعرض أرصدة النقدية والذمم والإيرادات المؤجلة</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="saas-panel saas-panel--accent saas-stagger-item">
        <div class="saas-panel__head">
            <div class="saas-panel__title-wrap">
                <span class="saas-panel__icon pos-icon-amber"><i class="fas fa-coins"></i></span>
                <h3 data-i18n="reports.runRevenue">اعتراف بالإيراد</h3>
            </div>
        </div>
        <div class="saas-panel__body">
            <form id="revenueForm" class="saas-form-grid">
                <div class="saas-field saas-col-3">
                    <label data-i18n="reports.periodEnd">نهاية الفترة</label>
                    <input class="form-control" name="periodEnd" type="date" required>
                </div>
                <div class="saas-field saas-col-2">
                    <label>&nbsp;</label>
                    <button class="btn saas-btn-soft saas-btn-with-icon w-100" type="submit">
                        <i class="fas fa-check-circle"></i><span data-i18n="reports.run">تشغيل</span>
                    </button>
                </div>
            </form>
            <div id="revenueResult" class="saas-report-output mt-3">
                <div class="saas-report-placeholder saas-report-placeholder--compact">
                    <i class="fas fa-receipt"></i>
                    <p data-i18n="reports.revenueHint">شغّل اعتراف الإيراد للفواتير المدفوعة</p>
                </div>
            </div>
        </div>
    </div>
</div>
<script src="/admin/js/reports.js"></script>
