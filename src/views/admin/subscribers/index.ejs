<div class="pos-kpi-grid mb-4" id="subscriberStatsRow">
    <div class="pos-kpi-card">
        <div class="pos-kpi-head">
            <span class="pos-kpi-label" data-i18n="subscribers.statTotalCompanies">إجمالي الشركات</span>
            <div class="pos-kpi-icon pos-icon-blue"><i class="fas fa-users"></i></div>
        </div>
        <p class="pos-kpi-value" id="statTotalSubscribers">—</p>
    </div>
    <div class="pos-kpi-card">
        <div class="pos-kpi-head">
            <span class="pos-kpi-label" data-i18n="subscribers.statMrr">MRR المنصة</span>
            <div class="pos-kpi-icon pos-icon-green"><i class="fas fa-crown"></i></div>
        </div>
        <p class="pos-kpi-value text-success" id="statPlatformMrr">—</p>
    </div>
    <div class="pos-kpi-card">
        <div class="pos-kpi-head">
            <span class="pos-kpi-label" data-i18n="subscribers.statBranches">فروع مسجّلة</span>
            <div class="pos-kpi-icon pos-icon-cyan"><i class="fas fa-store"></i></div>
        </div>
        <p class="pos-kpi-value" id="statPlatformBranches">—</p>
    </div>
    <div class="pos-kpi-card">
        <div class="pos-kpi-head">
            <span class="pos-kpi-label" data-i18n="subscribers.statCashiers">كاشيرز</span>
            <div class="pos-kpi-icon pos-icon-indigo"><i class="fas fa-user-tie"></i></div>
        </div>
        <p class="pos-kpi-value" id="statPlatformCashiers">—</p>
    </div>
    <div class="pos-kpi-card">
        <div class="pos-kpi-head">
            <span class="pos-kpi-label" data-i18n="subscribers.statDevices">أجهزة نشطة</span>
            <div class="pos-kpi-icon pos-icon-violet"><i class="fas fa-tablet-alt"></i></div>
        </div>
        <p class="pos-kpi-value" id="statPlatformDevices">—</p>
    </div>
    <div class="pos-kpi-card">
        <div class="pos-kpi-head">
            <span class="pos-kpi-label" data-i18n="subscribers.statActiveSubs">اشتراكات نشطة</span>
            <div class="pos-kpi-icon pos-icon-green"><i class="fas fa-check-circle"></i></div>
        </div>
        <p class="pos-kpi-value text-success" id="statActiveSubs">—</p>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-12">
        <div class="pos-card">
            <div class="pos-card-header">
                <h4 class="mb-0"><i class="fas fa-money-check-alt text-pos-primary"></i> <span data-i18n="subscribers.pendingTitle">مدفوعات بانتظار التأكيد</span></h4>
            </div>
            <p class="text-muted small px-3 mb-0" data-i18n="subscribers.pendingHint">التاجر يختار الخطة ويدفع — أكّد الدفع من هنا لتفعيل اشتراك الشركة.</p>
            <div class="table-responsive">
                <table class="table pos-table" id="pendingPaymentsTable">
                    <thead>
                        <tr>
                            <th data-i18n="subscribers.colRef">مرجع الدفع</th>
                            <th data-i18n="subscribers.colCompany">الشركة</th>
                            <th data-i18n="subscribers.colPlan">الخطة</th>
                            <th data-i18n="subscribers.colAmount">المبلغ</th>
                            <th data-i18n="subscribers.colReceipt">إيصال الدفع</th>
                            <th data-i18n="subscribers.colDate">التاريخ</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-12">
        <div class="pos-card">
            <div class="pos-card-header d-flex flex-wrap justify-content-between align-items-center gap-2">
                <h4 class="mb-0"><i class="fas fa-building text-pos-primary"></i> <span data-i18n="subscribers.listTitle">الشركات المشتركة</span></h4>
                <div class="d-flex gap-2 flex-wrap">
                    <select id="subscriberCountryFilter" class="form-select form-select-sm pos-input" style="width:auto">
                        <option value="" data-i18n="countries.filterAll">كل الدول</option>
                    </select>
                    <select id="subscriberFilter" class="form-select form-select-sm pos-input" style="width:auto">
                        <option value="" data-i18n="common.all">الكل</option>
                        <option value="pending" data-i18n="subscribers.filterPending">بانتظار الدفع</option>
                        <option value="no_subscription" data-i18n="subscribers.filterNoSubscription">بدون اشتراك نشط</option>
                        <option value="active" data-i18n="subscribers.filterActive">مفعّلون</option>
                    </select>
                    <button class="btn btn-pos-outline btn-sm" id="refreshSubscribers"><i class="fas fa-sync"></i></button>
                </div>
            </div>
            <p class="text-muted small px-3 mb-0" data-i18n="subscribers.listHint">بعد تأكيد الدفع، يُفعَّل اشتراك الشركة ويستطيع الكاشيرز التابعون لها تسجيل الدخول.</p>
            <div id="subscribersAlert" class="alert d-none pos-alert m-3"></div>
            <div class="table-responsive">
                <table class="table pos-table" id="subscribersTable">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th data-i18n="subscribers.colCompany">الشركة</th>
                            <th data-i18n="subscribers.colCountry">الدولة</th>
                            <th data-i18n="subscribers.colBranches">فروع</th>
                            <th data-i18n="subscribers.colCashiers">كاشيرز</th>
                            <th data-i18n="subscribers.colDevices">أجهزة</th>
                            <th data-i18n="subscribers.colMrr">MRR</th>
                            <th data-i18n="subscribers.colCompanyStatus">حالة الشركة</th>
                            <th data-i18n="platform.desktop">Desktop</th>
                            <th data-i18n="platform.mobile">Android</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="activateModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content pos-card border-0">
            <div class="modal-header">
                <h5 class="modal-title" data-i18n="subscribers.modalTitle">تفعيل بعد الدفع</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="activateCompanyId">
                <input type="hidden" id="activatePaymentId">
                <p class="text-muted small mb-1" id="activateCustomerInfo"></p>
                <p class="small text-pos-primary mb-3" id="activatePaymentRef"></p>
                <div class="mb-3 d-none" id="activateReceiptWrap">
                    <label class="form-label" data-i18n="subscribers.receiptPreview">إيصال الدفع</label>
                    <a id="activateReceiptLink" href="#" target="_blank" rel="noopener" class="d-inline-block">
                        <img id="activateReceiptImg" src="" alt="receipt" class="img-fluid rounded border" style="max-height:200px">
                    </a>
                </div>
                <div class="mb-3">
                    <label class="form-label" data-i18n="subscribers.modalPlanLabel">النسخة / الخطة</label>
                    <select id="activatePlanSelect" class="form-select pos-input" required></select>
                </div>
                <div class="mb-3">
                    <label class="form-label" data-i18n="subscribers.modalNotesLabel">ملاحظات (اختياري)</label>
                    <textarea id="activateNotes" class="form-control pos-input" rows="2" data-i18n-placeholder="subscribers.modalNotesPlaceholder" placeholder="رقم التحويل أو مرجع الدفع"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-pos-outline" data-bs-dismiss="modal" data-i18n="common.cancel">إلغاء</button>
                <button type="button" class="btn btn-pos-primary" id="confirmActivate" data-i18n="subscribers.modalActivate">تفعيل الاشتراك</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="companyDetailModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content pos-card border-0">
            <div class="modal-header">
                <h5 class="modal-title" data-i18n="subscribers.detailTitle">تفاصيل الشركة</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="companyDetailBody">
                <div class="text-center text-muted py-4"><span class="spinner-border spinner-border-sm"></span></div>
            </div>
        </div>
    </div>
</div>

<script src="/admin/js/subscribers.js"></script>
