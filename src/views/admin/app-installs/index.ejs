<div class="pos-kpi-grid mb-4" id="appInstallStatsRow">
    <div class="pos-kpi-card">
        <div class="pos-kpi-head">
            <span class="pos-kpi-label" data-i18n="appInstalls.statTotal">إجمالي التنزيلات</span>
            <div class="pos-kpi-icon pos-icon-blue"><i class="fas fa-download"></i></div>
        </div>
        <p class="pos-kpi-value" id="statInstallTotal">—</p>
    </div>
    <div class="pos-kpi-card">
        <div class="pos-kpi-head">
            <span class="pos-kpi-label" data-i18n="appInstalls.statAndroid">أندرويد</span>
            <div class="pos-kpi-icon pos-icon-green"><i class="fab fa-android"></i></div>
        </div>
        <p class="pos-kpi-value" id="statInstallAndroid">—</p>
    </div>
    <div class="pos-kpi-card">
        <div class="pos-kpi-head">
            <span class="pos-kpi-label" data-i18n="appInstalls.statIos">آيفون</span>
            <div class="pos-kpi-icon pos-icon-indigo"><i class="fab fa-apple"></i></div>
        </div>
        <p class="pos-kpi-value" id="statInstallIos">—</p>
    </div>
    <div class="pos-kpi-card">
        <div class="pos-kpi-head">
            <span class="pos-kpi-label" data-i18n="appInstalls.statDesktop">ديسكتوب</span>
            <div class="pos-kpi-icon pos-icon-violet"><i class="fas fa-desktop"></i></div>
        </div>
        <p class="pos-kpi-value" id="statInstallDesktop">—</p>
    </div>
    <div class="pos-kpi-card">
        <div class="pos-kpi-head">
            <span class="pos-kpi-label" data-i18n="appInstalls.statUnlinked">قبل التسجيل</span>
            <div class="pos-kpi-icon pos-icon-cyan"><i class="fas fa-user-clock"></i></div>
        </div>
        <p class="pos-kpi-value" id="statInstallUnlinked">—</p>
    </div>
</div>

<div class="row g-4">
    <div class="col-12">
        <div class="pos-card">
            <div class="pos-card-header d-flex flex-wrap justify-content-between align-items-center gap-2">
                <h4 class="mb-0"><i class="fas fa-mobile-alt text-pos-primary"></i> <span data-i18n="appInstalls.listTitle">تنزيلات التطبيق</span></h4>
                <div class="d-flex gap-2 flex-wrap">
                    <select id="installDeviceFilter" class="form-select form-select-sm pos-input" style="width:auto">
                        <option value="" data-i18n="appInstalls.filterAllDevices">كل الأجهزة</option>
                        <option value="android" data-i18n="appInstalls.filterAndroid">أندرويد</option>
                        <option value="ios" data-i18n="appInstalls.filterIos">آيفون</option>
                        <option value="web" data-i18n="appInstalls.filterDesktop">ديسكتوب</option>
                    </select>
                    <select id="installCountryFilter" class="form-select form-select-sm pos-input" style="width:auto">
                        <option value="" data-i18n="countries.filterAll">كل الدول</option>
                    </select>
                    <select id="installLinkedFilter" class="form-select form-select-sm pos-input" style="width:auto">
                        <option value="" data-i18n="common.all">الكل</option>
                        <option value="0" data-i18n="appInstalls.filterUnlinked">قبل التسجيل</option>
                        <option value="1" data-i18n="appInstalls.filterLinked">بعد التسجيل</option>
                    </select>
                    <input type="search" id="installSearch" class="form-control form-control-sm pos-input" style="width:160px" data-i18n-placeholder="appInstalls.searchPlaceholder" placeholder="بحث بالسيريال...">
                    <button class="btn btn-pos-outline btn-sm" id="refreshAppInstalls"><i class="fas fa-sync"></i></button>
                </div>
            </div>
            <p class="text-muted small px-3 mb-0" data-i18n="appInstalls.listHint">يُسجَّل أول فتح للتطبيق قبل تسجيل الدخول — Android و iOS و Desktop.</p>
            <div id="appInstallsAlert" class="alert d-none pos-alert m-3"></div>
            <div class="table-responsive">
                <table class="table pos-table" id="appInstallsTable">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th data-i18n="appInstalls.colDevice">الجهاز</th>
                            <th data-i18n="appInstalls.colSerial">السيريال</th>
                            <th data-i18n="appInstalls.colIp">IP</th>
                            <th data-i18n="appInstalls.colLocation">الموقع</th>
                            <th data-i18n="appInstalls.colCountry">الدولة</th>
                            <th data-i18n="appInstalls.colVersion">الإصدار</th>
                            <th data-i18n="appInstalls.colStatus">الحالة</th>
                            <th data-i18n="appInstalls.colInstalledAt">أول فتح</th>
                            <th data-i18n="appInstalls.colLastSeen">آخر ظهور</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script src="/socket.io/socket.io.js"></script>
<script src="/admin/js/app-installs.js"></script>
