<div class="saas-page">
    <div class="saas-hero-welcome">
        <h2><span data-i18n="home.welcome">مرحباً</span>, <%= user?.name || '' %></h2>
        <p data-i18n="home.desc">نظام إدارة اشتراكات SaaS متعدد الشركات مع محاسبة القيد المزدوج.</p>
    </div>

    <div class="pos-kpi-grid mb-2">
        <div class="pos-kpi-card">
            <div class="pos-kpi-head">
                <span class="pos-kpi-label" data-i18n="home.tenant">الشركة</span>
                <div class="pos-kpi-icon pos-icon-blue"><i class="fas fa-building"></i></div>
            </div>
            <p class="pos-kpi-value" style="font-size:1.1rem"><%= user?.tenant?.name || '—' %></p>
        </div>
        <div class="pos-kpi-card">
            <div class="pos-kpi-head">
                <span class="pos-kpi-label" data-i18n="home.accounting">المحاسبة</span>
                <div class="pos-kpi-icon pos-icon-green"><i class="fas fa-balance-scale"></i></div>
            </div>
            <p class="pos-kpi-value" style="font-size:1rem" data-i18n="home.accountingDesc">قيد مزدوج + إيرادات مؤجلة</p>
        </div>
    </div>

    <div class="saas-panel">
        <div class="saas-panel__head">
            <h3 data-i18n="home.quickActions">إجراءات سريعة</h3>
        </div>
        <div class="saas-panel__body">
            <div class="saas-quick-grid">
                <a href="/dashboard/ui/plans" class="saas-quick-card">
                    <div class="saas-quick-card__icon pos-icon-violet"><i class="fas fa-layer-group"></i></div>
                    <div><h4 data-i18n="nav.plans">الخطط</h4><p data-i18n="home.plansHint">إنشاء خطط Bronze و Gold</p></div>
                </a>
                <a href="/dashboard/ui/customers" class="saas-quick-card">
                    <div class="saas-quick-card__icon pos-icon-cyan"><i class="fas fa-users"></i></div>
                    <div><h4 data-i18n="nav.customers">العملاء</h4><p data-i18n="home.customersHint">إدارة عملاء الشركة</p></div>
                </a>
                <a href="/dashboard/ui/subscriptions" class="saas-quick-card">
                    <div class="saas-quick-card__icon pos-icon-indigo"><i class="fas fa-sync-alt"></i></div>
                    <div><h4 data-i18n="nav.subscriptions">الاشتراكات</h4><p data-i18n="home.subsHint">ربط العميل بالخطة</p></div>
                </a>
                <a href="/dashboard/ui/invoices" class="saas-quick-card">
                    <div class="saas-quick-card__icon pos-icon-amber"><i class="fas fa-file-invoice-dollar"></i></div>
                    <div><h4 data-i18n="nav.invoices">الفواتير</h4><p data-i18n="home.invoicesHint">تشغيل الفوترة الشهرية</p></div>
                </a>
                <a href="/dashboard/ui/payments" class="saas-quick-card">
                    <div class="saas-quick-card__icon pos-icon-green"><i class="fas fa-wallet"></i></div>
                    <div><h4 data-i18n="nav.payments">المدفوعات</h4><p data-i18n="home.paymentsHint">تسجيل الدفعات</p></div>
                </a>
                <a href="/dashboard/ui/reports" class="saas-quick-card">
                    <div class="saas-quick-card__icon pos-icon-rose"><i class="fas fa-chart-line"></i></div>
                    <div><h4 data-i18n="nav.reports">التقارير</h4><p data-i18n="home.reportsHint">قائمة الدخل والميزانية</p></div>
                </a>
            </div>
        </div>
    </div>
</div>
