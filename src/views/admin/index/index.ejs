<div class="saas-page saas-animate-in">
    <div class="saas-hero-welcome">
        <div class="saas-hero-welcome__content">
            <div class="saas-hero-welcome__badge"><i class="fas fa-star"></i> SaaS Billing</div>
            <h2><span data-i18n="home.welcome">مرحباً</span>, <%= user?.name || '' %>
            </h2>
            <p data-i18n="home.desc">نظام إدارة اشتراكات SaaS متعدد الشركات مع محاسبة القيد المزدوج.</p>
        </div>
        <div class="saas-hero-welcome__icons" aria-hidden="true">
            <span class="saas-float-icon saas-float-icon--1"><i class="fas fa-layer-group"></i></span>
            <span class="saas-float-icon saas-float-icon--2"><i class="fas fa-chart-pie"></i></span>
            <span class="saas-float-icon saas-float-icon--3"><i class="fas fa-wallet"></i></span>
        </div>
    </div>

    <div class="saas-stat-grid saas-stagger">
        <div class="saas-stat-card saas-stagger-item">
            <div class="saas-stat-card__icon pos-icon-blue"><i class="fas fa-building"></i></div>
            <div>
                <span class="saas-stat-card__label" data-i18n="home.tenant">الشركة</span>
                <p class="saas-stat-card__value">
                    <%= user?.tenant?.name || '—' %>
                </p>
            </div>
        </div>
        <div class="saas-stat-card saas-stagger-item">
            <div class="saas-stat-card__icon pos-icon-green"><i class="fas fa-balance-scale"></i></div>
            <div>
                <span class="saas-stat-card__label" data-i18n="home.accounting">المحاسبة</span>
                <p class="saas-stat-card__value saas-stat-card__value--sm" data-i18n="home.accountingDesc">قيد مزدوج +
                    إيرادات مؤجلة</p>
            </div>
        </div>
        <div class="saas-stat-card saas-stagger-item">
            <div class="saas-stat-card__icon pos-icon-violet"><i class="fas fa-shield-alt"></i></div>
            <div>
                <span class="saas-stat-card__label" data-i18n="home.isolation">عزل البيانات</span>
                <p class="saas-stat-card__value saas-stat-card__value--sm" data-i18n="home.isolationDesc">Multi-Tenant
                    آمن</p>
            </div>
        </div>
    </div>

    <div class="saas-panel saas-stagger-item">
        <div class="saas-panel__head">
            <div class="saas-panel__title-wrap">
                <span class="saas-panel__icon pos-icon-indigo"><i class="fas fa-bolt"></i></span>
                <h3 data-i18n="home.quickActions">إجراءات سريعة</h3>
            </div>
        </div>
        <div class="saas-panel__body">
            <div class="saas-quick-grid">
                <a href="/dashboard/ui/plans" class="saas-quick-card">
                    <div class="saas-quick-card__icon pos-icon-violet"><i class="fas fa-layer-group"></i></div>
                    <div class="saas-quick-card__body">
                        <h4 data-i18n="nav.plans">الخطط</h4>
                        <p data-i18n="home.plansHint">إنشاء خطط Bronze و Gold</p>
                    </div>
                    <span class="saas-quick-card__arrow"><i class="fas fa-arrow-left"></i></span>
                </a>
                <a href="/dashboard/ui/customers" class="saas-quick-card">
                    <div class="saas-quick-card__icon pos-icon-cyan"><i class="fas fa-users"></i></div>
                    <div class="saas-quick-card__body">
                        <h4 data-i18n="nav.customers">العملاء</h4>
                        <p data-i18n="home.customersHint">إدارة عملاء الشركة</p>
                    </div>
                    <span class="saas-quick-card__arrow"><i class="fas fa-arrow-left"></i></span>
                </a>
                <a href="/dashboard/ui/subscriptions" class="saas-quick-card">
                    <div class="saas-quick-card__icon pos-icon-indigo"><i class="fas fa-sync-alt"></i></div>
                    <div class="saas-quick-card__body">
                        <h4 data-i18n="nav.subscriptions">الاشتراكات</h4>
                        <p data-i18n="home.subsHint">ربط العميل بالخطة</p>
                    </div>
                    <span class="saas-quick-card__arrow"><i class="fas fa-arrow-left"></i></span>
                </a>
                <a href="/dashboard/ui/invoices" class="saas-quick-card">
                    <div class="saas-quick-card__icon pos-icon-amber"><i class="fas fa-file-invoice-dollar"></i></div>
                    <div class="saas-quick-card__body">
                        <h4 data-i18n="nav.invoices">الفواتير</h4>
                        <p data-i18n="home.invoicesHint">تشغيل الفوترة الشهرية</p>
                    </div>
                    <span class="saas-quick-card__arrow"><i class="fas fa-arrow-left"></i></span>
                </a>
                <a href="/dashboard/ui/payments" class="saas-quick-card">
                    <div class="saas-quick-card__icon pos-icon-green"><i class="fas fa-wallet"></i></div>
                    <div class="saas-quick-card__body">
                        <h4 data-i18n="nav.payments">المدفوعات</h4>
                        <p data-i18n="home.paymentsHint">تسجيل الدفعات</p>
                    </div>
                    <span class="saas-quick-card__arrow"><i class="fas fa-arrow-left"></i></span>
                </a>
                <a href="/dashboard/ui/reports" class="saas-quick-card saas-quick-card--highlight">
                    <div class="saas-quick-card__icon pos-icon-rose"><i class="fas fa-chart-line"></i></div>
                    <div class="saas-quick-card__body">
                        <h4 data-i18n="nav.reports">التقارير</h4>
                        <p data-i18n="home.reportsHint">قائمة الدخل والميزانية</p>
                    </div>
                    <span class="saas-quick-card__arrow"><i class="fas fa-arrow-left"></i></span>
                </a>
            </div>
        </div>
    </div>
</div>