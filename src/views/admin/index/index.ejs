<%
const fmt = (n) => Number(n || 0).toLocaleString('en-US');
const planName = user?.tenant?.planName || 'Free';
const perms = user?.role?.permissions || [];
const can = (p) => !p || perms.includes('*') || perms.includes(p);
%>
<div class="saas-page">
    <!-- HERO -->
    <section class="sp-hero sp-reveal">
        <span class="sp-hero__blob b1"></span>
        <span class="sp-hero__blob b2"></span>
        <span class="sp-hero__blob b3"></span>
        <div class="sp-hero__content">
            <span class="sp-hero__badge"><i class="fas fa-bolt"></i> SaaS Billing</span>
            <h1><span data-i18n="home.welcome">مرحباً</span><span>، <%= user?.name || '' %></span></h1>
            <p data-i18n="home.desc">نظام إدارة اشتراكات SaaS متعدد الشركات مع محاسبة القيد المزدوج.</p>
            <div class="sp-hero__meta">
                <div class="sp-hero__meta-item">
                    <small data-i18n="home.tenant">الشركة</small>
                    <strong><%= user?.tenant?.name || '—' %></strong>
                </div>
                <div class="sp-hero__meta-item">
                    <small data-i18n="home.totalRevenue">إجمالي الإيرادات</small>
                    <strong><%= fmt(stats.revenue) %> USD</strong>
                </div>
                <div class="sp-hero__meta-item">
                    <small data-i18n="nav.subscriptions">الاشتراكات النشطة</small>
                    <strong><%= fmt(stats.subscriptions) %></strong>
                </div>
            </div>
            <a href="/dashboard/ui/subscriptions" class="sp-hero__cta">
                <i class="fas fa-plus"></i> <span data-i18n="subscriptions.add">اشتراك جديد</span>
            </a>
        </div>
        <div class="sp-hero__art" aria-hidden="true">
            <span class="sp-float f1"><i class="fas fa-layer-group"></i></span>
            <span class="sp-float f2"><i class="fas fa-chart-pie"></i></span>
            <span class="sp-float f3"><i class="fas fa-wallet"></i></span>
        </div>
    </section>

    <!-- STAT CARDS -->
    <div class="sp-stat-grid">
        <div class="sp-stat sp-reveal">
            <div class="sp-stat__top">
                <div class="sp-stat__icon pos-icon-cyan"><i class="fas fa-users"></i></div>
                <span class="sp-stat__trend up"><i class="fas fa-arrow-up"></i> 12%</span>
            </div>
            <div class="sp-stat__label" data-i18n="nav.customers">العملاء</div>
            <div class="sp-stat__value" data-countup="<%= stats.customers %>">0</div>
        </div>
        <div class="sp-stat sp-reveal">
            <div class="sp-stat__top">
                <div class="sp-stat__icon pos-icon-indigo"><i class="fas fa-sync-alt"></i></div>
                <span class="sp-stat__trend up"><i class="fas fa-arrow-up"></i> 8%</span>
            </div>
            <div class="sp-stat__label" data-i18n="nav.subscriptions">الاشتراكات النشطة</div>
            <div class="sp-stat__value" data-countup="<%= stats.subscriptions %>">0</div>
        </div>
        <div class="sp-stat sp-reveal">
            <div class="sp-stat__top">
                <div class="sp-stat__icon pos-icon-green"><i class="fas fa-dollar-sign"></i></div>
                <span class="sp-stat__trend up"><i class="fas fa-arrow-up"></i> 23%</span>
            </div>
            <div class="sp-stat__label" data-i18n="home.totalRevenue">إجمالي الإيرادات</div>
            <div class="sp-stat__value" data-countup="<%= stats.revenue %>" data-suffix=" USD">0</div>
        </div>
        <div class="sp-stat sp-reveal">
            <div class="sp-stat__top">
                <div class="sp-stat__icon pos-icon-amber"><i class="fas fa-file-invoice-dollar"></i></div>
                <span class="sp-stat__trend down"><i class="fas fa-clock"></i></span>
            </div>
            <div class="sp-stat__label" data-i18n="home.openInvoices">فواتير مفتوحة</div>
            <div class="sp-stat__value" data-countup="<%= stats.openInvoices %>">0</div>
        </div>
    </div>

    <div class="row g-4">
        <!-- REVENUE CHART -->
        <div class="col-lg-8">
            <div class="saas-panel sp-reveal h-100">
                <div class="saas-panel__head sp-chart-head">
                    <div class="saas-panel__title-wrap">
                        <span class="saas-panel__icon pos-icon-violet"><i class="fas fa-chart-line"></i></span>
                        <h3 data-i18n="home.revenueOverview">نظرة عامة على الإيرادات</h3>
                    </div>
                    <div class="sp-chart-toolbar">
                        <div class="sp-chart-tabs" id="revenueChartTabs" role="tablist">
                            <button type="button" class="sp-chart-tab" data-granularity="daily" data-i18n="home.filterDaily">يومي</button>
                            <button type="button" class="sp-chart-tab active" data-granularity="monthly" data-i18n="home.filterMonthly">شهري</button>
                            <button type="button" class="sp-chart-tab" data-granularity="yearly" data-i18n="home.filterYearly">سنوي</button>
                            <button type="button" class="sp-chart-tab" data-granularity="custom" data-i18n="home.filterCustom">فترة</button>
                        </div>
                        <div class="sp-chart-custom d-none" id="revenueChartCustom">
                            <input type="date" class="form-control form-control-sm" id="revenueChartFrom">
                            <span class="sp-chart-sep">—</span>
                            <input type="date" class="form-control form-control-sm" id="revenueChartTo">
                            <button type="button" class="btn saas-btn-soft saas-btn-sm" id="revenueChartApply" data-i18n="home.applyFilter">تطبيق</button>
                        </div>
                        <span class="saas-badge saas-badge--info" id="revenueChartBadge"><%= chart.from %> → <%= chart.to %></span>
                    </div>
                </div>
                <div class="saas-panel__body">
                    <div class="sp-chart-summary">
                        <span data-i18n="home.chartTotal">إجمالي الفترة</span>
                        <strong id="revenueChartTotal"><%= fmt(chart.total || 0) %> USD</strong>
                    </div>
                    <div style="height: 280px; position: relative;">
                        <div class="sp-chart-loading d-none" id="revenueChartLoading"><i class="fas fa-spinner fa-spin"></i></div>
                        <canvas id="revenueChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <!-- COMPANY OVERVIEW -->
        <div class="col-lg-4">
            <div class="saas-panel sp-reveal h-100">
                <div class="saas-panel__head">
                    <div class="saas-panel__title-wrap">
                        <span class="saas-panel__icon pos-icon-blue"><i class="fas fa-building"></i></span>
                        <h3 data-i18n="home.tenantInfo">معلومات الشركة</h3>
                    </div>
                </div>
                <div class="saas-panel__body">
                    <div class="text-center mb-4">
                        <% if (user?.tenant?.logo) { %>
                            <img src="<%= /^(https?:|\/)/.test(user.tenant.logo) ? user.tenant.logo : '/assets/uploads/tenants/' + user.tenant.logo %>" alt="Logo" class="rounded-3 mb-2" style="max-height: 64px;">
                        <% } else { %>
                            <div class="sp-stat__icon pos-icon-blue mx-auto mb-2" style="width:64px;height:64px;font-size:1.5rem;"><i class="fas fa-building"></i></div>
                        <% } %>
                        <h5 class="mb-1" style="color:var(--sp-text);font-weight:800;"><%= user?.tenant?.name || '—' %></h5>
                        <p class="mb-0" style="color:var(--sp-muted);font-size:.8rem;"><%= user?.tenant?.companyEmail || user?.email || '' %></p>
                    </div>

                    <div class="sp-progress-row">
                        <div class="sp-progress-head"><span data-i18n="nav.customers">العملاء</span><span><%= fmt(stats.customers) %></span></div>
                        <div class="sp-progress"><span class="sp-progress__bar" data-value="<%= Math.min(stats.customers * 5, 100) %>"></span></div>
                    </div>
                    <div class="sp-progress-row">
                        <div class="sp-progress-head"><span data-i18n="nav.subscriptions">الاشتراكات</span><span><%= fmt(stats.subscriptions) %></span></div>
                        <div class="sp-progress"><span class="sp-progress__bar" data-value="<%= Math.min(stats.subscriptions * 10, 100) %>"></span></div>
                    </div>
                    <div class="sp-progress-row">
                        <div class="sp-progress-head"><span data-i18n="nav.plans">الخطط</span><span><%= fmt(stats.plans) %></span></div>
                        <div class="sp-progress"><span class="sp-progress__bar" data-value="<%= Math.min(stats.plans * 20, 100) %>"></span></div>
                    </div>

                    <a href="/dashboard/ui/reports" class="btn saas-btn-soft w-100 mt-3">
                        <i class="fas fa-chart-line me-2"></i> <span data-i18n="nav.reports">التقارير المالية</span>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mt-1">
        <!-- QUICK ACTIONS -->
        <div class="col-lg-8">
            <div class="saas-panel sp-reveal h-100">
                <div class="saas-panel__head">
                    <div class="saas-panel__title-wrap">
                        <span class="saas-panel__icon pos-icon-indigo"><i class="fas fa-bolt"></i></span>
                        <h3 data-i18n="home.quickActions">إجراءات سريعة</h3>
                    </div>
                </div>
                <div class="saas-panel__body">
                    <div class="sp-quick-grid">
                        <a href="/dashboard/ui/plans" class="sp-quick">
                            <div class="sp-quick__icon pos-icon-violet"><i class="fas fa-layer-group"></i></div>
                            <h4 data-i18n="nav.plans">الخطط</h4>
                            <p data-i18n="home.plansHint">إنشاء خطط Bronze و Gold</p>
                            <span class="sp-quick__arrow"><i class="fas fa-arrow-left"></i></span>
                        </a>
                        <a href="/dashboard/ui/customers" class="sp-quick">
                            <div class="sp-quick__icon pos-icon-cyan"><i class="fas fa-users"></i></div>
                            <h4 data-i18n="nav.customers">العملاء</h4>
                            <p data-i18n="home.customersHint">إدارة عملاء الشركة</p>
                            <span class="sp-quick__arrow"><i class="fas fa-arrow-left"></i></span>
                        </a>
                        <a href="/dashboard/ui/invoices" class="sp-quick">
                            <div class="sp-quick__icon pos-icon-amber"><i class="fas fa-file-invoice-dollar"></i></div>
                            <h4 data-i18n="nav.invoices">الفواتير</h4>
                            <p data-i18n="home.invoicesHint">تشغيل الفوترة الشهرية</p>
                            <span class="sp-quick__arrow"><i class="fas fa-arrow-left"></i></span>
                        </a>
                        <a href="/dashboard/ui/users" class="sp-quick">
                            <div class="sp-quick__icon pos-icon-indigo"><i class="fas fa-user-shield"></i></div>
                            <h4 data-i18n="nav.users">المستخدمين</h4>
                            <p data-i18n="users.desc">إدارة فريق العمل والأدوار</p>
                            <span class="sp-quick__arrow"><i class="fas fa-arrow-left"></i></span>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- RECENT ACTIVITY -->
        <div class="col-lg-4">
            <div class="saas-panel sp-reveal h-100">
                <div class="saas-panel__head">
                    <div class="saas-panel__title-wrap">
                        <span class="saas-panel__icon pos-icon-green"><i class="fas fa-clock-rotate-left"></i></span>
                        <h3 data-i18n="home.recentActivity">آخر النشاطات</h3>
                    </div>
                </div>
                <div class="saas-panel__body">
                    <% if (!activity || !activity.length) { %>
                        <div class="saas-empty"><i class="fas fa-inbox"></i><div data-i18n="common.noData">لا توجد بيانات بعد</div></div>
                    <% } else { %>
                        <div class="sp-timeline">
                            <% activity.forEach((a) => { %>
                                <div class="sp-timeline__item">
                                    <span class="sp-timeline__dot <%= a.type === 'payment' ? 'g' : 'a' %>"></span>
                                    <div class="sp-timeline__title">
                                        <%= a.customer %> · <%= fmt(a.amount) %> USD
                                    </div>
                                    <div class="sp-timeline__meta">
                                        <i class="fas <%= a.type === 'payment' ? 'fa-check-circle' : 'fa-file-invoice' %>"></i>
                                        <span data-i18n="status.<%= a.type === 'payment' ? 'paid' : 'open' %>"><%= a.type %></span>
                                        · <%= a.date || '' %>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="/admin/js/home-chart.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        HomeChart.init({
            canvasId: 'revenueChart',
            initial: <%- JSON.stringify(chart) %>,
        });
    });
</script>
