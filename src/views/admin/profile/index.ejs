<%
const pAvatar = user?.avatar ? (/^(https?:|\/)/.test(user.avatar) ? user.avatar : '/assets/uploads/users/' + user.avatar) : null;
%>
<div class="saas-page saas-animate-in">
    <%- include('../../partials/page-header', { titleKey: 'profile.title', descKey: 'profile.desc' }) %>
    <div id="profileAlert" class="alert d-none saas-alert"></div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="saas-panel text-center">
                <div class="saas-panel__body">
                    <div class="position-relative d-inline-block">
                        <div id="avatarWrapper" class="rounded-circle border bg-light d-flex align-items-center justify-content-center mx-auto" style="width: 120px; height: 120px; overflow: hidden;">
                            <img id="avatarPreview" src="<%= pAvatar || '' %>" alt="Avatar" class="<%= pAvatar ? '' : 'd-none' %>" style="width: 100%; height: 100%; object-fit: cover;">
                            <i id="avatarIcon" class="fas fa-user text-muted <%= pAvatar ? 'd-none' : '' %>" style="font-size: 48px;"></i>
                        </div>
                        <label for="avatarInput" class="btn btn-sm saas-btn-primary position-absolute bottom-0 end-0 rounded-circle p-0" style="width: 36px; height: 36px; line-height: 36px; cursor: pointer;">
                            <i class="fas fa-camera"></i>
                        </label>
                        <input type="file" id="avatarInput" name="avatar" class="d-none" accept="image/*" form="profileForm">
                    </div>
                    <h3 class="mt-3 mb-1"><%= user?.name || '' %></h3>
                    <p class="text-muted mb-2"><%= user?.email || '' %></p>
                    <span class="saas-badge"><i class="fas fa-shield-halved me-1"></i><%= user?.role?.name || 'Owner' %></span>
                    <div class="small text-muted mt-2" data-i18n="profile.avatarHint">اضغط على الكاميرا لتغيير الصورة</div>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <form id="profileForm" enctype="multipart/form-data">
                <div class="saas-panel mb-4">
                    <div class="saas-panel__head"><h3 data-i18n="profile.accountInfo">بيانات الحساب</h3></div>
                    <div class="saas-panel__body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label small fw-bold" data-i18n="profile.name">الاسم</label>
                                <input class="form-control" name="name" value="<%= user?.name || '' %>" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold" data-i18n="profile.email">البريد الإلكتروني</label>
                                <input class="form-control" name="email" type="email" value="<%= user?.email || '' %>" required>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="saas-panel mb-4">
                    <div class="saas-panel__head"><h3 data-i18n="profile.changePassword">تغيير كلمة المرور</h3></div>
                    <div class="saas-panel__body">
                        <div class="small text-muted mb-3" data-i18n="profile.passwordHint">اتركها فارغة إذا كنت لا تريد تغيير كلمة المرور</div>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label small fw-bold" data-i18n="profile.currentPassword">كلمة المرور الحالية</label>
                                <div class="pos-auth-field">
                                    <i class="fas fa-lock pos-auth-field-icon"></i>
                                    <input class="form-control pos-auth-input" name="currentPassword" id="currentPassword" type="password" autocomplete="current-password">
                                    <button type="button" class="pos-auth-eye" data-password-toggle="currentPassword" aria-label="Show password"><i class="fas fa-eye"></i></button>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold" data-i18n="profile.newPassword">كلمة المرور الجديدة</label>
                                <div class="pos-auth-field">
                                    <i class="fas fa-lock pos-auth-field-icon"></i>
                                    <input class="form-control pos-auth-input" name="newPassword" id="newPassword" type="password" minlength="8" autocomplete="new-password">
                                    <button type="button" class="pos-auth-eye" data-password-toggle="newPassword" aria-label="Show password"><i class="fas fa-eye"></i></button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-end">
                    <button class="btn saas-btn-primary" type="submit" id="profileSubmit">
                        <i class="fas fa-save me-2"></i><span data-i18n="common.save">حفظ التغييرات</span>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
<script src="/admin/js/profile.js"></script>
