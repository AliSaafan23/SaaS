<div class="saas-page saas-animate-in">
    <%- include('../../partials/page-header', { titleKey: 'subscriptions.title', descKey: 'subscriptions.desc' }) %>
    <div id="subAlert" class="alert d-none saas-alert"></div>

    <div class="saas-panel">
        <div class="saas-panel__head"><h3 data-i18n="subscriptions.add">اشتراك جديد</h3></div>
        <div class="saas-panel__body">
            <form id="subForm">
                <div class="saas-form-card">
                    <div class="saas-form-grid">
                        <div class="saas-field saas-col-3">
                            <label data-i18n="subscriptions.customer">العميل</label>
                            <select class="form-select" name="customerId" id="subCustomer" required></select>
                        </div>
                        <div class="saas-field saas-col-3">
                            <label data-i18n="subscriptions.plan">الخطة</label>
                            <select class="form-select" name="planId" id="subPlan" required></select>
                        </div>
                        <div class="saas-field saas-col-2">
                            <label data-i18n="subscriptions.startDate">تاريخ البدء</label>
                            <input class="form-control" name="startDate" type="date" required>
                        </div>
                        <div class="saas-field saas-col-2">
                            <label>&nbsp;</label>
                            <button class="btn saas-btn-primary w-100" type="submit" data-i18n="subscriptions.add">إضافة</button>
                        </div>
                    </div>
                </div>
            </form>
            <div class="saas-table-wrap">
                <table class="saas-table" id="subsTable">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th data-i18n="subscriptions.customer">العميل</th>
                            <th data-i18n="subscriptions.plan">الخطة</th>
                            <th data-i18n="subscriptions.startDate">البدء</th>
                            <th>Next billing</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>
<script src="/admin/js/subscriptions.js"></script>
