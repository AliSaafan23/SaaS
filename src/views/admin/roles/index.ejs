<div class="row g-4">
    <div class="col-lg-5">
        <div class="pos-card">
            <div class="pos-card-header">
                <h4><i class="fas fa-key text-pos-primary"></i> <span data-i18n="roles.formTitle">إنشاء دور</span></h4>
            </div>
            <div id="roleFormAlert" class="alert d-none pos-alert"></div>
            <form id="roleForm">
                <div class="mb-3">
                    <label class="form-label" data-i18n="roles.nameAr">اسم الدور (عربي)</label>
                    <input type="text" name="name_ar" class="form-control pos-input" required>
                </div>
                <div class="mb-3">
                    <label class="form-label" data-i18n="roles.nameEn">اسم الدور (English)</label>
                    <input type="text" name="name_en" class="form-control pos-input">
                </div>
                <div class="mb-3">
                    <label class="form-label" data-i18n="roles.color">اللون</label>
                    <input type="color" name="color" class="form-control form-control-color pos-input" value="#6366f1">
                </div>
                <div class="mb-3">
                    <label class="form-label d-block" data-i18n="roles.permissions">الصلاحيات</label>
                    <div id="permissionsList" class="pos-permissions-grid"></div>
                </div>
                <button type="submit" class="btn btn-pos-primary w-100" data-i18n="roles.save">حفظ الدور</button>
            </form>
        </div>
    </div>
    <div class="col-lg-7">
        <div class="pos-card">
            <div class="pos-card-header d-flex justify-content-between align-items-center">
                <h4><i class="fas fa-list text-pos-primary"></i> <span data-i18n="roles.listTitle">الأدوار</span></h4>
                <button class="btn btn-pos-outline btn-sm" id="refreshRoles"><i class="fas fa-sync"></i></button>
            </div>
            <div class="table-responsive">
                <table class="table pos-table" id="rolesTable">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th data-i18n="roles.colName">الاسم</th>
                            <th data-i18n="roles.colPermissions">الصلاحيات</th>
                            <th data-i18n="roles.colStatus">الحالة</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script src="/admin/js/roles.js"></script>
